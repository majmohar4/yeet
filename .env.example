# Required: Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here

# Required for admin panel access
ADMIN_PASSWORD=change_this_strong_password

# Optional overrides (shown with defaults)
# MAX_FILE_SIZE=104857600      # 100MB in bytes
# STORAGE_LIMIT=10737418240    # 10GB in bytes
# FILE_EXPIRY_HOURS=24         # Hours until files expire

# ClamAV virus scanning (set to false to disable)
# ClamAV runs inside the container — works on ARM64 and x86_64
# CLAMAV_ENABLED=true
# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310

# Rate limiting
# RATE_LIMIT_UPLOADS=10        # Max uploads per IP per hour
# RATE_LIMIT_DOWNLOADS=100     # Max downloads per IP per hour
